{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AuditVPS Findings",
  "type": "array",
  "items": {
    "type": "object",
    "required": ["id", "title", "category", "severity", "summary", "affected_objects", "evidence", "suggested_checks", "precautions", "status"],
    "properties": {
      "id": {"type": "string"},
      "title": {"type": "string"},
      "category": {"type": "string"},
      "severity": {"type": "string"},
      "summary": {"type": "string"},
      "affected_objects": {"type": "array", "items": {"type": "string"}},
      "evidence": {"type": "array", "items": {"type": ["string", "object"]}},
      "suggested_checks": {"type": "array", "items": {"type": "string"}},
      "precautions": {"type": "array", "items": {"type": "string"}},
      "status": {"type": "string"}
    }
  }
}
