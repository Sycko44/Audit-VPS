    "required": ["id", "kind", "name", "path", "tags", "risk_level", "sensitivity", "status", "source_refs"],
    "properties": {
      "id": {"type": "string"},
      "kind": {"type": "string"},
      "name": {"type": "string"},
      "path": {"type": "string"},
      "tags": {"type": "array", "items": {"type": "string"}},
      "risk_level": {"type": "string"},
      "sensitivity": {"type": "string"},
      "status": {"type": "string"},
      "source_refs": {"type": "array", "items": {"type": "string"}}
    }
  }
}
